{
  "name": "sk8dvlpr/securepayload-ci4",
  "description": "CodeIgniter 4 integration for sk8dvlpr/securepayload — filter and client library.",
  "type": "library",
  "license": "MIT",
  "authors": [{ "name": "sk8dvlpr" }],
  "require": {
    "php": ">=8.0",
    "codeigniter4/framework": "^4.7",
    "sk8dvlpr/securepayload": "^2.7"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6 || ^10.5",
    "phpstan/phpstan": "^1.11"
  },
  "autoload": {
    "psr-4": {
      "SecurePayload\\Ci4\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SecurePayload\\Ci4\\Tests\\": "tests/"
    }
  },
  "repositories": [
    {
      "type": "path",
      "url": "../..",
      "options": { "symlink": true }
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
