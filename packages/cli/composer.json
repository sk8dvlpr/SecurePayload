{
  "name": "sk8dvlpr/securepayload-cli",
  "description": "CLI tooling for sk8dvlpr/securepayload — key generation, debug verify, roundtrip test.",
  "type": "library",
  "license": "MIT",
  "authors": [{ "name": "sk8dvlpr" }],
  "require": {
    "php": ">=8.0",
    "symfony/console": "^5.4|^6.4|^7.0",
    "sk8dvlpr/securepayload": "^2.7 || ^3.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.6 || ^10.5",
    "phpstan/phpstan": "^1.11"
  },
  "autoload": {
    "psr-4": {
      "SecurePayload\\Cli\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SecurePayload\\Cli\\Tests\\": "tests/"
    }
  },
  "bin": ["bin/securepayload"],
  "repositories": [
    {
      "type": "path",
      "url": "../..",
      "options": { "symlink": true }
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
